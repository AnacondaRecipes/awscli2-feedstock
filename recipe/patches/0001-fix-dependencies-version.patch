diff --git a/pyproject.toml b/pyproject.toml
index f122f1d..e7b2fde 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -32,18 +32,21 @@ classifiers = [
 dependencies = [
     "colorama>=0.2.5,<0.4.7",
     "docutils>=0.10,<0.20",
-    "ruamel.yaml>=0.15.0,<=0.17.21",
+    "ruamel.yaml>=0.15.0,<=0.17.21; python_version <= '3.12'",
+    "ruamel.yaml==0.18.6; python_version > '3.12'",
     # ruamel.yaml only requires ruamel.yaml.clib for Python versions
     # less than or equal to Python 3.10. In order to ensure we have
     # a consistent dependency closure across all Python versions,
     # we explicitly include ruamel.yaml.clib as a dependency.
     "ruamel.yaml.clib>=0.2.0,<=0.2.12",
-    "prompt-toolkit>=3.0.24,<3.0.39",
+    "prompt-toolkit>=3.0.24,<3.0.39; python_version <= '3.12'",
+    "prompt-toolkit==3.0.43; python_version > '3.12'",
     "distro>=1.5.0,<1.9.0",
-    "awscrt==0.26.1",
+    "awscrt>=0.26.1",
     "python-dateutil>=2.1,<=2.9.0",
     "jmespath>=0.7.1,<1.1.0",
-    "urllib3>=1.25.4,<1.27",
+    "urllib3>=1.25.4,<1.27; python_version <= '3.12'",
+    "urllib3==2.2.3; python_version > '3.12'"
 ]
 dynamic = ["version"]
 
